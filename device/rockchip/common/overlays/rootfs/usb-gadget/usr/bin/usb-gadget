#!/bin/bash
#
# Usage:
# usb-gadget [start|update|stop]
#
# Hookable stages:
# usb_<pre|post>_<init|prepare|start|stop|restart>_hook
# <usb function>_<pre|post>_<prepare|start|stop>_hook
#
# Example hook:
# root@RK3588:/# more /etc/usb-gadget.d/usb_init.sh
# #!/bin/sh
# usb_pre_init_hook()
# {
#	echo "usb pre-init hook"
# }
#
# root@RK3588:/# more /etc/usb-gadget.d/uvc.sh
# #!/bin/sh
# UVC_INSTANCES="uvc.0 uvc.1"
#
# root@rk3588:/# more /etc/usb-gadget.d/rndis.sh
# #!/bin/sh
# rndis_post_start_hook()
# {
# 	while ! ifconfig usb0 >/dev/null 2>&1; do
# 		sleep .1
# 	done
# 	ifconfig usb0 192.168.1.1
# }
#
# root@rk3588:/# more /etc/usb-gadget.d/ums.sh
# #!/bin/bash
# UMS1_FILE=${UMS1_FILE:-/userdata/ums1_shared.img}
# UMS1_SIZE=${UMS1_SIZE:-256M}
# UMS1_FSTYPE=${UMS1_FSTYPE:-vfat}
# UMS1_MOUNT=${UMS1_MOUNT:-0}
# UMS1_MOUNTPOINT=${UMS1_MOUNTPOINT:-/mnt/ums1}
# UMS1_RO=${UMS1_RO:-0}
#
# UMS2_FILE=${UMS2_FILE:-/userdata/ums2_shared.img}
# UMS2_SIZE=${UMS2_SIZE:-256M}
# UMS2_FSTYPE=${UMS2_FSTYPE:-vfat}
# UMS2_MOUNT=${UMS2_MOUNT:-0}
# UMS2_MOUNTPOINT=${UMS2_MOUNTPOINT:-/mnt/ums2}
# UMS2_RO=${UMS2_RO:-0}
#
# UMS_INSTANCES="mass_storage.0 mass_storage.1"
# ums_setup()
# {
# 	case $instance in
# 		mass_storage.0)
# 			UMS_FILE=$UMS1_FILE
# 			UMS_SIZE=$UMS1_SIZE
# 			UMS_FSTYPE=$UMS1_FSTYPE
# 			UMS_MOUNT=$UMS1_MOUNT
# 			UMS_MOUNTPOINT=$UMS1_MOUNTPOINT
# 			UMS_RO=$UMS1_RO
# 			;;
# 		mass_storage.1)
# 			UMS_FILE=$UMS2_FILE
# 			UMS_SIZE=$UMS2_SIZE
# 			UMS_FSTYPE=$UMS2_FSTYPE
# 			UMS_MOUNT=$UMS2_MOUNT
# 			UMS_MOUNTPOINT=$UMS2_MOUNTPOINT
# 			UMS_RO=$UMS2_RO
# 			;;
# 	esac
# }
# ums_pre_prepare_hook()
# {
# 	ums_setup
# }
# ums_pre_start_hook()
# {
# 	ums_setup
# }
# ums_pre_stop_hook()
# {
# 	ums_setup
# }

[ -z "$DEBUG" ] || set -x

# Load default env variables from profiles
. /etc/profile

# Enable error out after loading env
set -e

TMP_DIR=/var/run/usb-gadget
mkdir -p $TMP_DIR

LOCK_FILE=$TMP_DIR/lock
USB_FUNCS_FILE=$TMP_DIR/funcs
USB_CONFIGURED_FILE=$TMP_DIR/configured
USB_CMD_FILE=$TMP_DIR/commands

LOG_DIR=/var/log
LOG_FILE=$LOG_DIR/usb-gadget.log

ln -sf $LOG_DIR/usb-commands.log $USB_CMD_FILE

CONFIGFS_DIR=/sys/kernel/config
USB_GROUP=rockchip
USB_STRINGS_ATTR=strings/0x409
USB_GADGET_DIR=$CONFIGFS_DIR/usb_gadget/$USB_GROUP
USB_GADGET_STRINGS_DIR=$USB_GADGET_DIR/$USB_STRINGS_ATTR
USB_FUNCTIONS_DIR=$USB_GADGET_DIR/functions
USB_CONFIGS_DIR=$USB_GADGET_DIR/configs/b.1
USB_CONFIGS_STRINGS_DIR=$USB_CONFIGS_DIR/$USB_STRINGS_ATTR

USB_SERVICE_NAME=usb-service

# ---- helper functions
usb_msg()
{
	if which logger >/dev/null; then
		logger -t "$(basename "$0")" "[$BASHPID]: $@"
	fi
	echo "[$(date +"%F %T")] $(basename "$0") [$BASHPID]: $@"
}

usb_lock()
{
	touch $LOCK_FILE
	exec 3<$LOCK_FILE
	flock -x 3
}

usb_unlock()
{
	flock -u 3
	exec 3<&- # Close lock file
}

usb_daemon_prepare()
{
	# Close opened files
	exec 0<&- # input (cmd file?)
	exec 3<&- # lock file

	cd /; cd /

	# Apply process name
	if [ "$1" ]; then
		echo -n $1 > /proc/$BASHPID/comm
	fi
}

usb_service_is_running()
{
	grep -wl "^$USB_SERVICE_NAME$" /proc/*/comm 2>/dev/null | \
		grep -wq "comm$"
}

usb_enable()
{
	touch $USB_FUNCS_FILE
}

usb_disable()
{
	usb_set_disconnected
	rm -f $USB_FUNCS_FILE
}

usb_is_enabled()
{
	[ -f $USB_FUNCS_FILE ]
}

usb_clear_started()
{
	echo > $USB_FUNCS_FILE
}

usb_set_started()
{
	echo $USB_FUNCS > $USB_FUNCS_FILE
}

usb_get_started()
{
	usb_is_enabled || return 0
	cat $USB_FUNCS_FILE
}

usb_is_configured()
{
	[ -f $USB_CONFIGURED_FILE ]
}

usb_set_configured()
{
	touch $USB_CONFIGURED_FILE
}

usb_set_disconnected()
{
	rm -f $USB_CONFIGURED_FILE
}

usb_daemon_file()
{
	echo $TMP_DIR/usb_daemon_$instance
}

usb_daemon()
{
	if usb_daemon_is_enabled; then
		cut "$(usb_daemon_file)" -d' ' -f1
	fi
}

usb_daemon_enable()
{
	echo $@ > $(usb_daemon_file)
}

usb_daemon_disable()
{
	rm -f $(usb_daemon_file)
}

usb_daemon_is_enabled()
{
	[ -f "$(usb_daemon_file)" ]
}

# Based on <<Rockchip_Developer_Guide_USB_CN>> V2.0.0
usb_pid()
{
	case "$(echo $USB_FUNCS | xargs -n 1 | sort | xargs | tr ' ' '-')" in
		ums)			echo 0x0000;;
		mtp)			echo 0x0001;; # For Android
		ptp)			echo 0x0002;; # For Android
		rndis)			echo 0x0003;;
		midi)			echo 0x0004;; # For Android
		uvc)			echo 0x0005;; # For Android
		adb)			echo 0x0006;; # Single ADB
		# mtp)			echo 0x0007;; # For Android
		# ptp)			echo 0x0008;; # For Android
		ntb)			echo 0x0009;; # For next Computing-Stick
		# ums)			echo 0x0010;; # For U-Boot
		# adb-ums)		echo 0x0010;; # Out-dated
		adb-mtp)		echo 0x0011;;
		# adb-ptp)		echo 0x0012;; # For Android
		adb-rndis)		echo 0x0013;; # For Android
		adb-midi)		echo 0x0014;; # For Android
		adb-uvc)		echo 0x0015;; # For Android
		adb-uac[12]-uvc|adb-uvc-rndis)	echo 0x0016;;
		# adb-mtp)		echo 0x0017;; # For Android
		adb-ums)		echo 0x0018;;
		# adb-ptp)		echo 0x0018;; # For Android
		# ntb)			echo 0x0018;; # For Computing-Stick
		# hid-ntb|ntb-rndis)	echo 0x0019;; # For next Computing-Stick
		adb-*|*-adb|*-adb-*)	echo 0x0011;; # Undefined composite ADB
		*)			echo 0x00ff;; # Undefined
	esac
}

usb_instances()
{
	for func in $@; do
		VAR=$(echo $func | tr 'a-z' 'A-Z')_INSTANCES
		eval echo "\${$VAR:-$func.0}"
	done
}

usb_run_stage()
{
	for f in $1_pre_$2_hook $1_$2 $1_post_$2_hook; do
		type $f >/dev/null 2>/dev/null || continue

		usb_msg "Run stage: $f"
		eval $f || return 1
	done
}

usb_wait_access()
{
	for i in `seq 200`;do
		if fuser -s $@ 2>/dev/null; then
			return 0
		fi
		sleep .01
	done
	return 1
}

usb_release()
{
	for i in `seq 200`;do
		fuser -s -k $@ 2>/dev/null || break
		sleep .01
	done
}

# usage: usb_mount <src> <mountpoint> <options>
usb_mount()
{
	mkdir -p $2

	# Already mounted
	if mountpoint -q $2; then
		return 0
	fi

	{
		# Prepare for fuse daemon
		usb_daemon_prepare

		mount $@
	}&
}

usb_umount()
{
	mountpoint -q $1 || return 0
	usb_release -m $1
	umount $1
}

usb_symlink()
{
	mkdir -p $1
	mkdir -p $(dirname $2)
	[ -e $2 ] || ln -s $1 $2
}

usb_do_start_daemon()
{
	DAEMON=$1
	shift
	ARGS=$@

	usb_msg "Starting daemon: $DAEMON $ARGS"

	/sbin/start-stop-daemon -Sqx $DAEMON -- $ARGS >> \
		$LOG_DIR/$(basename $(usb_daemon_file)).log 2>&1 || true

	# The daemon might fork itself
	while /sbin/start-stop-daemon -Kqtx $DAEMON; do
		sleep .5
	done

	usb_msg "Exited daemon: $DAEMON $ARGS"
}

usb_start_daemon()
{
	# Already started
	if usb_daemon_is_enabled; then
		return 0
	fi

	# Enable spawn
	usb_daemon_enable $@

	# Start and spawn background daemon
	{
		usb_daemon_prepare ${instance}-daemon

		# Don't spawn after stopped
		while usb_daemon_is_enabled; do
			usb_do_start_daemon $@
			sleep .5
		done
	}&
}

usb_kill_daemon()
{
	DAEMON="${1:-$(usb_daemon)}"
	if [ "$DAEMON" ]; then
		usb_msg "Killing daemon: $DAEMON"
		/sbin/start-stop-daemon -Kqox $DAEMON || true
	fi
}

usb_stop_daemon()
{
	usb_daemon_is_enabled || return 0

	DAEMON="$(usb_daemon)"

	usb_msg "Stopping daemon: $DAEMON"
	usb_daemon_disable
	usb_kill_daemon $DAEMON
}

usb_load_config()
{
	USB_CONFIG_FILE=$(find /tmp/ /etc/ -name .usb_config | head -n 1)
	[ -n "$USB_CONFIG_FILE" -a -r "$USB_CONFIG_FILE" ] || return 0

	usb_msg "Loading configs from $USB_CONFIG_FILE"

	ums_parse()
	{
		grep "\<$1=" "$USB_CONFIG_FILE" | cut -d'=' -f2
	}
	UMS_FILE="$(ums_parse ums_block)"
	UMS_SIZE=$(ums_parse ums_block_size || echo 0)M
	UMS_FSTYPE=$(ums_parse ums_block_type)
	UMS_MOUNT=$([ "$(ums_parse ums_block_auto_mount)" != on ] || echo 1)
	UMS_RO=$([ "$(ums_parse ums_block_ro)" != on ] || echo 1)

	USB_FUNCS="$(sed -n "s/usb_\(.*\)_en/\1/p" "$USB_CONFIG_FILE" | xargs)"
}

# ---- adb
ADB_INSTANCES=${ADB_INSTANCES:-ffs.adb}

adb_prepare()
{
	usb_mount ${instance#ffs.} /dev/usb-ffs/adb -t functionfs
	/sbin/ifup --force lo 2>/dev/null || /sbin/ifup -f lo 2>/dev/null
	usb_start_daemon /usr/bin/adbd
	usb_wait_access -m /dev/usb-ffs/adb
}

# ---- ntb
NTB_INSTANCES=${NTB_INSTANCES:-ffs.ntb}

ntb_prepare()
{
	usb_mount ${instance#ffs.} /dev/usb-ffs/ntb -t functionfs
	usb_start_daemon /usr/bin/ntbd
	usb_wait_access -m /dev/usb-ffs/ntb
}

# ---- mtp
MTP_INSTANCES=${MTP_INSTANCES:-ffs.mtp}
mtp_prepare()
{
	usb_mount ${instance#ffs.} /dev/usb-ffs/mtp -t functionfs
	usb_start_daemon /usr/bin/umtprd
	usb_wait_access -m /dev/usb-ffs/mtp
}

# ---- uac1
uac1_prepare()
{
	echo 3 > p_chmask
	echo 2 > p_ssize
	echo 8000,16000,44100,48000 > p_srate

	echo 3 > c_chmask
	echo 2 > c_ssize
	echo 4 > req_number
	echo 8000,16000,44100,48000 > c_srate

	# Enable volume control
	for f in $(find . -name "*_feature_unit"); do
		echo 1 >$f
	done
}

# ---- uac2
uac2_prepare()
{
	uac1_prepare

	# Disable UAC 2.0 volume control by default for Windows system
	for f in $(find . -name "*_feature_unit"); do
		echo 0 >$f
	done
}

# ---- uvc
uvc_frame_interval()
{
	WIDTH=$(echo $2 | cut -d'x' -f1)
	HEIGHT=$(echo $2 | cut -d'x' -f2)

	case $1 in
		yuyv)
			if [ $WIDTH -ge 1280 ]; then
				# echo "1000000\n2000000"
				echo "333333\n666666\n1000000\n2000000"
			else
				echo "333333\n666666\n1000000\n2000000"
			fi
			;;
		mjpeg)
			echo "333333\n666666\n1000000\n2000000"
			;;
		h264)
			echo "333333\n400000\n500000\n666666\n1000000\n2000000"
			;;
		h265)
			echo "333333\n400000\n500000"
			;;
	esac
}

uvc_add_yuyv()
{
	FRAME_INTERVAL=$(uvc_frame_interval yuyv $1)
	WIDTH=$(echo $1 | cut -d'x' -f1)
	HEIGHT=$(echo $1 | cut -d'x' -f2)
	DIR=streaming/uncompressed/u/${HEIGHT}p

	[ ! -d $DIR ] || return 0

	mkdir -p $DIR
	echo $WIDTH > $DIR/wWidth
	echo $HEIGHT > $DIR/wHeight
	echo -e $FRAME_INTERVAL | head -n 1 > $DIR/dwDefaultFrameInterval
	echo $((WIDTH * HEIGHT * 20)) > $DIR/dwMinBitRate
	echo $((WIDTH * HEIGHT * 20)) > $DIR/dwMaxBitRate
	echo $((WIDTH * HEIGHT * 2)) > $DIR/dwMaxVideoFrameBufferSize
	echo -e "$FRAME_INTERVAL" | tee $DIR/dwFrameInterval
}

uvc_add_mjpeg()
{
	FRAME_INTERVAL=$(uvc_frame_interval mjpeg $1)
	WIDTH=$(echo $1 | cut -d'x' -f1)
	HEIGHT=$(echo $1 | cut -d'x' -f2)
	DIR=streaming/mjpeg/m/${HEIGHT}p

	[ ! -d $DIR ] || return 0

	mkdir -p $DIR
	echo $WIDTH > $DIR/wWidth
	echo $HEIGHT > $DIR/wHeight
	echo -e $FRAME_INTERVAL | head -n 1 > $DIR/dwDefaultFrameInterval
	echo $((WIDTH * HEIGHT * 20)) > $DIR/dwMinBitRate
	echo $((WIDTH * HEIGHT * 20)) > $DIR/dwMaxBitRate
	echo $((WIDTH * HEIGHT * 2)) > $DIR/dwMaxVideoFrameBufferSize
	echo -e "$FRAME_INTERVAL" | tee $DIR/dwFrameInterval
}

uvc_add_h264()
{
	FRAME_INTERVAL=$(uvc_frame_interval h264 $1)
	WIDTH=$(echo $1 | cut -d'x' -f1)
	HEIGHT=$(echo $1 | cut -d'x' -f2)
	DIR=streaming/framebased/f1/${HEIGHT}p

	[ ! -d $DIR ] || return 0

	mkdir -p $DIR
	echo $WIDTH > $DIR/wWidth
	echo $HEIGHT > $DIR/wHeight
	echo -e $FRAME_INTERVAL | head -n 1 > $DIR/dwDefaultFrameInterval
	echo $((WIDTH * HEIGHT * 10)) > $DIR/dwMinBitRate
	echo $((WIDTH * HEIGHT * 10)) > $DIR/dwMaxBitRate
	echo -e "$FRAME_INTERVAL" | tee $DIR/dwFrameInterval
}

uvc_add_h265()
{
	FRAME_INTERVAL=$(uvc_frame_interval h265 $1)
	WIDTH=$(echo $1 | cut -d'x' -f1)
	HEIGHT=$(echo $1 | cut -d'x' -f2)
	DIR=streaming/framebased/f2/${HEIGHT}p

	[ ! -d $DIR ] || return 0

	mkdir -p $DIR
	echo $WIDTH > $DIR/wWidth
	echo $HEIGHT > $DIR/wHeight
	echo -e $FRAME_INTERVAL | head -n 1 > $DIR/dwDefaultFrameInterval
	echo $((WIDTH * HEIGHT * 10)) > $DIR/dwMinBitRate
	echo $((WIDTH * HEIGHT * 10)) > $DIR/dwMaxBitRate
	echo -e "$FRAME_INTERVAL" | tee $DIR/dwFrameInterval
}

uvc_support_resolutions()
{
	case ${1:-yuyv} in
		yuyv)	echo "320x240 640x360 640x480 1280x720 1920x1080" ;;
		mjpeg)	echo "320x240 640x360 640x480 768x448 1280x720 \
			1024x768 1920x1080 2560x1440" ;;
		h264)	echo "640x480 1280x720 1920x1080 2560x1440 3840x2160" ;;
		h265)	echo "640x480 1280x720 1920x1080 2560x1440 3840x2160" ;;
	esac
}

uvc_prepare()
{
	UVC_DIR=$(pwd)

	UVC_YUYV_RES=$(uvc_support_resolutions yuyv)
	if [ -n "$UVC_YUYV_RES" ]; then
		for res in $UVC_YUYV_RES; do
			uvc_add_yuyv $res >/dev/null
		done

		usb_symlink $UVC_DIR/streaming/uncompressed/u \
			$UVC_DIR/streaming/header/h/u
	fi

	UVC_MJPEG_RES=$(uvc_support_resolutions mjpeg)
	if [ -n "$UVC_MJPEG_RES" ]; then
		for res in $UVC_MJPEG_RES; do
			uvc_add_mjpeg $res >/dev/null
		done

		usb_symlink $UVC_DIR/streaming/mjpeg/m \
			$UVC_DIR/streaming/header/h/m
	fi

	UVC_H264_RES=$(uvc_support_resolutions h264)
	if [ -n "$UVC_H264_RES" ]; then
		for res in $UVC_H264_RES; do
			uvc_add_h264 $res >/dev/null
		done

		echo -ne H264 > $UVC_DIR/streaming/framebased/f1/guidFormat \
			2>/dev/null || true

		usb_symlink $UVC_DIR/streaming/framebased/f1 \
			$UVC_DIR/streaming/header/h/f1
	fi

	UVC_H265_RES=$(uvc_support_resolutions h265)
	if [ -n "$UVC_H265_RES" ]; then
		for res in $UVC_H265_RES; do
			uvc_add_h265 $res >/dev/null
		done

		echo -ne H265 > $UVC_DIR/streaming/framebased/f2/guidFormat \
			2>/dev/null || true

		usb_symlink $UVC_DIR/streaming/framebased/f2 \
			$UVC_DIR/streaming/header/h/f2
	fi

	echo 3072 > $UVC_DIR/streaming_maxpacket 2>/dev/null || true
	echo 2 > $UVC_DIR/uvc_num_request 2>/dev/null || true
	echo 5 > $UVC_DIR/streaming_maxburst 2>/dev/null || true

	usb_symlink $UVC_DIR/control/header/h $UVC_DIR/control/class/fs/h
	usb_symlink $UVC_DIR/control/header/h $UVC_DIR/control/class/ss/h

	usb_symlink $UVC_DIR/streaming/header/h $UVC_DIR/streaming/class/fs/h
	usb_symlink $UVC_DIR/streaming/header/h $UVC_DIR/streaming/class/hs/h
	usb_symlink $UVC_DIR/streaming/header/h $UVC_DIR/streaming/class/ss/h

	# Start your UVC daemon
	usb_start_daemon /usr/bin/uvc-gadget $instance
}

# ---- hid
hid_prepare()
{
	# Already prepared
	if [ "$(wc -c < report_desc)" -ne 0 ]; then
		return 0
	fi

	echo 1 > protocol
	echo 1 > subclass
	echo 8 > report_length
	echo -ne "\\x05\\x01\\x09\\x06\\xa1\\x01\\x05\\x07\\x19\\xe0\\x29\\xe7\\x15\\x00\\x25\\x01\\x75\\x01\\x95\\x08\\x81\\x02\\x95\\x01\\x75\\x08\\x81\\x03\\x95\\x05\\x75\\x01\\x05\\x08\\x19\\x01\\x29\\x05\\x91\\x02\\x95\\x01\\x75\\x03\\x91\\x03\\x95\\x06\\x75\\x08\\x15\\x00\\x25\\x65\\x05\\x07\\x19\\x00\\x29\\x65\\x81\\x00\\xc0" \
		> report_desc
}

# ---- ums
UMS_INSTANCES=${UMS_INSTANCES:-mass_storage.0}

ums_format()
{
	usb_msg "Formating $UMS_FILE($UMS_SIZE) to $UMS_FSTYPE"

	truncate -s $UMS_SIZE "$UMS_FILE"
	case "$UMS_FSTYPE" in
		ntfs) mkntfs -FQ "$UMS_FILE" ;;
		*) mkfs.$UMS_FSTYPE "$UMS_FILE" ;;
	esac
}

ums_prepare()
{
	if [ ! -f "$UMS_FILE" ] && [ ! -b "$UMS_FILE" ]; then
		if ! ums_format; then
			usb_msg "Failed to format $UMS_FILE to $UMS_FSTYPE"
		fi
	fi
}

ums_to_pc()
{
	if [ "$(cat lun.0/ro)" != "$UMS_RO" ]; then
		echo > lun.0/file
		echo $UMS_RO > lun.0/ro
	fi

	if ! grep -wq "$UMS_FILE" lun.0/file; then
		usb_umount "$UMS_MOUNTPOINT"

		# CDROM
		if echo "$UMS_FILE" | grep -q ".iso$"; then
			echo 1 > lun.0/cdrom
		fi

		fsck -t "$UMS_FSTYPE" -y "$UMS_FILE" || true
		echo "$UMS_FILE" > lun.0/file
	fi
}

ums_to_device()
{
	echo > lun.0/file
	fsck -t "$UMS_FSTYPE" -y "$UMS_FILE" || true

	[ "$UMS_MOUNT" -eq 1 ] || return 0

	usb_umount "$UMS_MOUNTPOINT"

	# Try auto fstype firstly
	usb_mount "$UMS_FILE" "$UMS_MOUNTPOINT" -o sync 2>/dev/null || \
		usb_mount "$UMS_FILE" "$UMS_MOUNTPOINT" -o sync -t $UMS_FSTYPE || \
		usb_mount "$UMS_FILE" "$UMS_MOUNTPOINT" -o sync,loop -t $UMS_FSTYPE
}

ums_start()
{
	case "$USB_STATE" in
		configured) ums_to_pc ;;
		*) ums_to_device ;;
	esac
}

ums_stop()
{
	echo > lun.0/file

	if [ "$UMS_MOUNT" ]; then
		usb_umount "$UMS_MOUNTPOINT"
	fi
}

# ---- global
usb_init()
{
	# Clean it up before initializing.
	usb_disable

	usb_msg "Initializing"

	cd $USB_GADGET_DIR

	printf "0x%x" ${USB_VENDOR_ID:-0x2207} > idVendor
	printf "0x%x" ${USB_FW_VERSION:-0x0310} > bcdDevice

	mkdir -p $USB_GADGET_STRINGS_DIR
	SERIAL=$(grep Serial /proc/cpuinfo | cut -d':' -f2)
	echo ${USB_SERIAL:-${SERIAL:-0123456789ABCDEF}} > \
		$USB_GADGET_STRINGS_DIR/serialnumber
	echo ${USB_MANUFACTUER:-Rockchip}  > $USB_GADGET_STRINGS_DIR/manufacturer
	echo ${USB_PRODUCT:-rk3xxx}  > $USB_GADGET_STRINGS_DIR/product

	mkdir -p $USB_CONFIGS_DIR
	echo 500 > $USB_CONFIGS_DIR/MaxPower

	echo 0x1 > os_desc/b_vendor_code
	echo MSFT100 > os_desc/qw_sign
	ln -s $USB_CONFIGS_DIR os_desc/

	mkdir -p $USB_CONFIGS_STRINGS_DIR
}

usb_funcs_grep()
{
	echo $USB_FUNCS | xargs -n 1 | sort | uniq | grep $@ || true
}

usb_funcs_sort()
{
	# Orders required by kernel
	FUNCS="rndis uac uvc ntb ums mtp acm"
	{
		for func in $FUNCS; do
			usb_funcs_grep $func
		done
		usb_funcs_grep -vE $(echo $FUNCS adb | tr ' ' '|')
		usb_funcs_grep adb
	} | uniq | xargs
}

usb_prepare()
{
	usb_load_config

	# Allow function/variable overriding
	if [ -d /etc/usb-gadget.d ]; then
		for hook in $(find /etc/usb-gadget.d/ -type f); do
			source "$hook"
		done
	fi

	UMS_FILE=${UMS_FILE:-/userdata/ums_shared.img}
	UMS_SIZE=${UMS_SIZE:-256M}
	UMS_FSTYPE=${UMS_FSTYPE:-vfat}
	UMS_MOUNT=${UMS_MOUNT:-0}
	UMS_MOUNTPOINT="${UMS_MOUNTPOINT:-/mnt/ums}"
	UMS_RO=${UMS_RO:-0}
	USB_FUNCS=${USB_FUNCS:-adb}
	USB_FUNCS="$(echo "$USB_FUNCS" | tr ',' ' ')"

	USB_FUNCS="$(echo "$USB_FUNCS" | usb_funcs_sort)"
	USB_CONFIG="$(echo "$USB_FUNCS" | tr ' ' '_')"

	if [ ! -d $USB_GADGET_DIR ]; then
		mountpoint -q $CONFIGFS_DIR || \
			mount -t configfs none $CONFIGFS_DIR

		mkdir -p $USB_GADGET_DIR
		cd $USB_GADGET_DIR

		# Global initialize
		usb_run_stage usb init || return 1
	fi

	USB_UDC=${USB_UDC:-$(ls /sys/class/udc/ | head -n 1)}
	if [ -z "$USB_UDC" ] || [ ! -d /sys/class/udc/$USB_UDC ]; then
		usb_msg "Failed to find a valid UDC device..."
		return 1
	fi

	usb_msg "Using USB UDC device: $USB_UDC"

	USB_STATE=$(cat /sys/class/udc/$USB_UDC/state)
	usb_msg "USB state: ${USB_STATE:-unknown}"

	# Stop old USB functions when USB functions changed
	OLD_FUNCS=$(usb_get_started)
	if [ -n "$OLD_FUNCS" ] && [ "$OLD_FUNCS" != "$USB_FUNCS" ]; then
		usb_msg "Functions changed $OLD_FUNCS -> $USB_FUNCS"
		usb_run_stage usb stop
	fi

	# Update USB PID
	printf "0x%x" ${USB_PRODUCT_ID:-$(usb_pid)} > $USB_GADGET_DIR/idProduct
}

usb_start()
{
	usb_msg "Starting functions: $USB_FUNCS"

	echo "$USB_CONFIG" > $USB_CONFIGS_STRINGS_DIR/configuration

	case "$USB_STATE" in
		configured) usb_set_configured ;;
		*)
			if usb_is_configured; then
				usb_msg "Reconfigure after disconnected"

				if [ "$(cat $USB_GADGET_DIR/UDC)" ]; then
					echo > $USB_GADGET_DIR/UDC
				fi

				for func in $USB_FUNCS; do
					for instance in $(usb_instances $func); do
						usb_kill_daemon
					done
				done
			fi

			usb_set_disconnected
			;;
	esac

	for func in $USB_FUNCS; do
		for instance in $(usb_instances $func); do
			usb_msg "Preparing instance: $instance"

			if ! mkdir -p $USB_FUNCTIONS_DIR/$instance \
				2>/dev/null; then
				usb_msg "Failed to create instance: $instance"
				continue
			fi

			cd $USB_FUNCTIONS_DIR/$instance \
				>/dev/null 2>/dev/null || continue

			usb_run_stage $func prepare || return 1

			# Make symlink after prepared (required by UVC)
			usb_symlink $USB_FUNCTIONS_DIR/$instance \
				$USB_CONFIGS_DIR/f-$instance
		done
	done

	if ! grep -q "^$USB_UDC$" $USB_GADGET_DIR/UDC; then
		echo "$USB_UDC" > $USB_GADGET_DIR/UDC
	fi

	for func in $USB_FUNCS; do
		for instance in $(usb_instances $func); do
			cd $USB_FUNCTIONS_DIR/$instance \
				>/dev/null 2>/dev/null || continue

			usb_msg "Starting instance: $instance"
			usb_run_stage $func start || return 1
		done
	done

	# Store started functions
	usb_set_started
}

usb_stop()
{
	usb_set_disconnected

	if [ "$UDC" ] && [ "$(cat $USB_GADGET_DIR/UDC)" ]; then
		echo > $USB_GADGET_DIR/UDC
	fi

	OLD_FUNCS=$(usb_get_started)
	if [ -n "$OLD_FUNCS" ]; then
		usb_msg "Stopping functions: $OLD_FUNCS"
		for func in $OLD_FUNCS; do
			for instance in $(usb_instances $func); do
				cd $USB_FUNCTIONS_DIR/$instance \
					>/dev/null 2>/dev/null || continue

				usb_msg "Stopping instance: $instance"
				usb_stop_daemon
				usb_run_stage $func stop
			done
		done

		# Clear functions to avoid stopping them again
		usb_clear_started
	fi

	rm -f $USB_CONFIGS_DIR/f-*

	# Keep ffs instances registered and mounted, to avoid random crashes
	find $USB_FUNCTIONS_DIR -mindepth 1 -maxdepth 1 ! -name 'ffs.*' | \
		xargs rmdir 2>/dev/null || true
}

usb_restart()
{
	usb_do_handle_request stop
	usb_do_handle_request start
}

usb_do_handle_request()
{
	case "$1" in
		start|update)
			usb_enable
			usb_run_stage usb start
			;;
		stop)
			usb_run_stage usb stop
			usb_disable
			;;
		restart)
			usb_run_stage usb restart
			;;
		*) usb_msg "Unknown request $1!" ;;
	esac
}

usb_handle_request()
{
	usb_msg "Handling $ACTION request..."

	# Nothing to update when disabled
	if [ "$ACTION" = update ] && ! usb_is_enabled; then
		return 0
	fi

	# Nothing to do when USB gadget not available
	if ! usb_run_stage usb prepare; then
		usb_run_stage usb stop
		return 0
	fi

	usb_do_handle_request $ACTION

	usb_msg "Done $ACTION request"
	echo
}

usb_service()
{
	# Fall back to busybox's fuser
	if ! which fuser >/dev/null; then
		if busybox --list | grep -wq fuser; then
			shopt -s expand_aliases
			alias fuser='busybox fuser'
		fi
	fi

	# Check fuser
	if ! fuser /dev/null | tee /dev/null >/dev/null; then
		echo "Your fuser is missing, please install it."
		return 1
	fi

	# Initial clean up
	usb_run_stage usb stop

	# USB gadget service
	{
		usb_daemon_prepare $USB_SERVICE_NAME

		if [ -z "$DEBUG" ]; then
			usb_msg "Starting $USB_SERVICE_NAME($$)," \
				"log saved to $LOG_FILE"

			# Redirect outputs to log file
			exec >>$LOG_FILE 2>&1
		fi

		# Poll and handle requests
		echo > $USB_CMD_FILE
		tail -f $USB_CMD_FILE | while true; do
			# Error and EOF
			if ! read -r ACTION || [ -z "$ACTION" ]; then
				continue
			fi

			usb_lock
			usb_handle_request
			usb_unlock

			if [ "$ACTION" = stop ]; then
				usb_msg "Exited $USB_SERVICE_NAME"
				exit 0
			fi
		done
	}&

	# Sync service status
	for i in `seq 100`;do
		if usb_service_is_running; then
			return 0
		fi
		sleep .01
	done

	usb_msg "Failed to start $USB_SERVICE_NAME"
	return 1
}

usb_lock

ACTION=${1:-update}

case "$ACTION" in
	start|restart)
		# Make sure that the USB gadget service is running
		if ! usb_service_is_running; then
			usb_service
		fi
		;& # fall-through
	update|stop)
		if ! usb_service_is_running; then
			usb_msg "$USB_SERVICE_NAME is unavailable"
			exit 0
		fi

		# Send request to the service
		usb_msg "Sending $ACTION request to service..."
		usb_msg "Check $LOG_FILE for $USB_SERVICE_NAME log..."
		echo $ACTION >> $USB_CMD_FILE
		;;
	*)
		echo "Usage: $(basename "$0") [start|stop|restart|update]" >&2
		;;
esac

usb_unlock
