# persistent internal storage links(Android style): /dev/block/by-name
#
# based on udev's 60-persistent-storage.rules

SUBSYSTEM!="block", GOTO="persistent_storage_end"
ACTION=="remove", GOTO="persistent_storage_end"

# ignore removable storage devices
IMPORT{builtin}="path_id"
ATTR{removable}=="1", GOTO="persistent_storage_end"

# ignore SD Cards
ATTRS{TYPE}=="SD", GOTO="persistent_storage_end"

# ignore USB devices
ENV{ID_BUS}=="usb", GOTO="persistent_storage_end"
ENV{ID_USB_DRIVER}=="usb-storage", GOTO="persistent_storage_end"

# honor various naming schemes
IMPORT{builtin}="blkid"
ENV{ID_PART_ENTRY_NAME}=="?*", \
	SYMLINK+="block/by-name/$env{ID_PART_ENTRY_NAME}"
ENV{PARTNAME}=="?*", SYMLINK+="block/by-name/$env{PARTNAME}"
ENV{ID_FS_LABEL}=="?*", SYMLINK+="block/by-name/$env{ID_FS_LABEL}"

# handle MTD devices
KERNEL=="mtdblock*", TEST=="device/name", \
	SYMLINK+="block/by-name/$attr{device/name}"

LABEL="persistent_storage_end"
