#!/bin/sh

LOG_FILE=/tmp/usb-eject.log

get_udc() {
    ls /sys/class/udc/ 2>/dev/null | head -n 1
}

monitor_udc() {
    UDC=$(get_udc)

    if [ -z "$UDC" ]; then
        echo "[$(date)] No UDC found" >> $LOG_FILE
        return 1
    fi

    STATE_FILE="/sys/class/udc/$UDC/state"
    echo "[$(date)] UDC: $UDC" >> $LOG_FILE

    LAST_STATE=""

    while true; do
        STATE=$(cat "$STATE_FILE" 2>/dev/null)

        if [ "$STATE" != "$LAST_STATE" ]; then
            echo "[$(date)] state changed: $LAST_STATE -> $STATE" >> $LOG_FILE

            # Detect safe removal / disconnect
            if [ "$LAST_STATE" = "configured" ] && [ "$STATE" != "configured" ]; then
                echo "[$(date)] device ejected" >> $LOG_FILE
            fi

            LAST_STATE="$STATE"
        fi

        sleep 0.5
    done
}

case "$1" in
    start)
        echo "Starting UDC monitor"
        monitor_udc &
        ;;
    stop)
        echo "Stopping UDC monitor"
        killall monitor_udc 2>/dev/null
        ;;
    restart|reload)
        $0 stop
        $0 start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
esac